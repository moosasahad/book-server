{
    "compilerOptions": {
        "target": "ES6",
        "module": "commonjs",
        "lib": [
            "es6"
        ],
        "allowJs": true,
        "checkJs": false,
        "outDir": "dist",
        "rootDir": ".",
        "strict": false,
        "noImplicitAny": false,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": [
        "**/*.js",
        "**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}